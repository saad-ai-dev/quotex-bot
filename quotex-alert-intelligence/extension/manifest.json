{
  "manifest_version": 3,
  "name": "Quotex Alert Intelligence",
  "description": "ALERT-ONLY chart observation and signal analysis system",
  "version": "1.0.0",
  "permissions": ["storage", "notifications", "activeTab", "alarms"],
  "host_permissions": [
    "https://quotex.io/*",
    "https://*.quotex.io/*",
    "https://quotex.com/*",
    "https://*.quotex.com/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://quotex.io/*",
        "https://*.quotex.io/*",
        "https://quotex.com/*",
        "https://*.quotex.com/*"
      ],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Quotex Alert Intelligence"
  },
  "options_page": "options/index.html",
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": [
        "https://quotex.io/*",
        "https://*.quotex.io/*",
        "https://quotex.com/*",
        "https://*.quotex.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
